---
import { getStrings, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);

const links = [
  { href: '#photography', label: t.nav.photography },
  { href: '#code', label: t.nav.code },
  { href: '#about', label: t.nav.about },
  { href: '#contact', label: t.nav.contact },
];
---

<nav
  aria-label="Primary"
  class="absolute inset-x-0 top-0 z-30 flex items-center justify-between gap-6 px-6 py-6 sm:px-10 sm:py-8"
>
  <a href="#top" class="label tracking-[0.2em] text-[var(--color-text)]">
    {t.name}
  </a>

  <div class="flex items-center gap-6 sm:gap-10">
    <ul class="hidden gap-8 sm:flex">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="label link-accent text-[var(--color-mute)]">
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="label flex items-center gap-2 text-[var(--color-mute)]">
      <a
        href="/"
        hreflang="en"
        aria-current={locale === 'en' ? 'page' : undefined}
        class={
          locale === 'en'
            ? 'text-[var(--color-text)]'
            : 'link-accent'
        }
      >
        {t.langSwitch.en}
      </a>
      <span aria-hidden="true">·</span>
      <a
        href="/ru/"
        hreflang="ru"
        aria-current={locale === 'ru' ? 'page' : undefined}
        class={
          locale === 'ru'
            ? 'text-[var(--color-text)]'
            : 'link-accent'
        }
      >
        {t.langSwitch.ru}
      </a>
    </div>
  </div>
</nav>
