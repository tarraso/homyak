---
import { getStrings, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
---

<section id="code" class="relative px-6 py-28 sm:px-10 sm:py-36 lg:px-16">
  <div class="mx-auto max-w-3xl">
    <h2 class="label mb-10 text-[var(--color-text)]">{t.code.heading}</h2>
    <p
      class="font-[var(--font-display)] text-xl leading-relaxed text-[var(--color-text)]/90 sm:text-2xl sm:leading-[1.6]"
      style="font-weight: 300;"
    >
      {t.code.bodyBefore}<a
        href="https://github.com/tarraso"
        rel="me noreferrer"
        target="_blank"
        class="link-accent text-[var(--color-text)]"
      >{t.code.linkText}</a>{t.code.bodyAfter}
    </p>
  </div>
</section>
