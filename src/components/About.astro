---
import { getStrings, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
---

<section id="about" class="relative px-6 py-28 sm:px-10 sm:py-36 lg:px-16">
  <div class="mx-auto max-w-3xl">
    <h2 class="label mb-10 text-[var(--color-text)]">{t.about.heading}</h2>
    <div
      class="space-y-6 font-[var(--font-display)] text-2xl leading-relaxed text-[var(--color-text)]/90 sm:text-[1.7rem] sm:leading-[1.55]"
      style="font-weight: 300;"
    >
      <p>{t.about.p1}</p>
      <p class="text-[1.05rem] leading-[1.75] text-[var(--color-mute)] sm:text-lg">
        {t.about.p2}
      </p>
    </div>
  </div>
</section>
