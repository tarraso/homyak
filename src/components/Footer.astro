---
import { getStrings, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getStrings(locale);
const year = new Date().getFullYear();
---

<footer class="px-6 pb-10 pt-20 sm:px-10 lg:px-16">
  <div
    class="mx-auto flex max-w-6xl items-center justify-between border-t border-[var(--color-line)] pt-8"
  >
    <p class="label text-[var(--color-mute)]">© {year} {t.name} · {t.footer.city}</p>
    <p class="label text-[var(--color-mute)]">taras.rocks</p>
  </div>
</footer>
